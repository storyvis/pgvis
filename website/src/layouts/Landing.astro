---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = "pgvis turns any Postgres database into MCP tools, a PostgREST-compatible REST API, and an OpenAPI 3.0 spec — from one I/O-free Rust engine.",
  canonical,
  ogImage = "/og-image.svg",
} = Astro.props;

const SITE_URL = "https://pgvis.io";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString();
const absoluteOgImage = new URL(ogImage, SITE_URL).toString();
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "pgvis",
  description,
  url: SITE_URL,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Linux, macOS, Windows",
  programmingLanguage: "Rust",
  license: "https://opensource.org/licenses/Apache-2.0",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Organization",
    name: "Storyvis AI",
    url: "https://github.com/storyvis",
  },
  codeRepository: "https://github.com/storyvis/pgvis",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="pgvis, PostgREST alternative, MCP server, Model Context Protocol, Postgres REST API, OpenAPI Postgres, Rust database API, embeddable database API, LLM database tools, AI agents Postgres"
    />
    <meta name="author" content="Storyvis AI" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#6366f1" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="pgvis" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:alt" content="pgvis — Postgres to MCP, REST, and OpenAPI" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/landing.css" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo" aria-label="pgvis home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect x="0" y="0" width="32" height="32" rx="7" fill="url(#logo-grad)" />
            <path d="M8 11h16M8 16h16M8 21h10" stroke="white" stroke-width="2.2" stroke-linecap="round" />
            <defs>
              <linearGradient id="logo-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                <stop stop-color="#6366f1" />
                <stop offset="1" stop-color="#8b5cf6" />
              </linearGradient>
            </defs>
          </svg>
          <span>pgvis</span>
        </a>
        <div class="nav-links">
          <a href="/docs/introduction">Docs</a>
          <a href="/vision">Vision</a>
          <a href="/blog">Blog</a>
          <a
            href="https://github.com/storyvis/pgvis"
            class="nav-github"
            aria-label="pgvis on GitHub"
            rel="noopener"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.51-1.47.11-3.07 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.6.23 2.78.11 3.07.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </nav>
    </header>
    <slot />
    <footer>
      <div class="container footer-grid">
        <div class="footer-col">
          <div class="footer-brand">
            <svg width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <rect x="0" y="0" width="32" height="32" rx="7" fill="url(#footer-logo-grad)" />
              <path d="M8 11h16M8 16h16M8 21h10" stroke="white" stroke-width="2.2" stroke-linecap="round" />
              <defs>
                <linearGradient id="footer-logo-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#6366f1" />
                  <stop offset="1" stop-color="#8b5cf6" />
                </linearGradient>
              </defs>
            </svg>
            <span>pgvis</span>
          </div>
          <p>Postgres → MCP, REST, OpenAPI — from one Rust engine.</p>
          <p class="footer-built-by">
            Built by <a href="https://storyvis.ai" rel="noopener">Storyvis AI</a>
          </p>
        </div>
        <div class="footer-col">
          <h4>Product</h4>
          <a href="/docs/introduction">Documentation</a>
          <a href="/docs/quickstart">Quick Start</a>
          <a href="/docs/reference/architecture">Architecture</a>
        </div>
        <div class="footer-col">
          <h4>Community</h4>
          <a href="https://github.com/storyvis/pgvis" rel="noopener">GitHub</a>
          <a href="https://github.com/storyvis/pgvis/issues" rel="noopener">Issues</a>
          <a href="/blog">Blog</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href="https://storyvis.ai" rel="noopener">Storyvis AI</a>
          <a href="/vision">Vision &amp; Roadmap</a>
          <a href="https://github.com/storyvis" rel="noopener">GitHub org</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href="https://modelcontextprotocol.io" rel="noopener">Model Context Protocol</a>
          <a href="https://postgrest.org" rel="noopener">PostgREST</a>
          <a href="https://github.com/storyvis/pgvis/blob/main/LICENSE" rel="noopener">License</a>
        </div>
      </div>
      <div class="footer-bottom container">
        <span>© {new Date().getFullYear()} Storyvis AI · Licensed under Apache-2.0</span>
        <a
          class="footer-github"
          href="https://github.com/storyvis/pgvis"
          aria-label="pgvis on GitHub"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.51-1.47.11-3.07 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.6.23 2.78.11 3.07.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
            ></path>
          </svg>
          storyvis/pgvis
        </a>
      </div>
    </footer>
  </body>
</html>
