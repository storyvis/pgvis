---
import Layout from "../layouts/Landing.astro";

// Phase-based milestones. The project is pre-release — no tags or release
// notes published yet — so we deliberately avoid version numbers here.
// Source of truth for shipped vs in-progress: the crate code and README.
const milestones = [
  {
    phase: "Today",
    status: "shipped",
    title: "REST, OpenAPI, MCP on Postgres &amp; SQLite",
    body: "Working from `main`: REST + OpenAPI on both Postgres and SQLite, MCP tools generated from the same introspected schema, the I/O-free engine, and the `pgvis-lib` `Builder` facade.",
  },
  {
    phase: "Hardening",
    status: "in-progress",
    title: "MCP stdio polish",
    body: "Tighten the MCP stdio surface: error handling, tool descriptions, schema discovery. Works with any MCP client.",
  },
  {
    phase: "Next",
    status: "planned",
    title: "MCP over SSE",
    body: "Server-Sent Events transport for MCP, so agents can stream alongside the existing stdio and Streamable-HTTP options.",
  },
  {
    phase: "1.0",
    status: "planned",
    title: "Stable embed API &amp; first tagged release",
    body: "Lock the `pgvis-lib` Builder and core surface so downstream Rust apps can depend on it without churn. First git tag and published release notes will land here.",
  },
];

const statusLabels: Record<string, string> = {
  shipped: "Shipped",
  "in-progress": "In progress",
  planned: "Planned",
};
---

<Layout
  title="Vision &amp; Roadmap — pgvis"
  description="Where pgvis is going: a hardened MCP surface, MCP over SSE, a stable embed API — all open source under Apache-2.0."
>
  <main>
    <section class="hero">
      <div class="container">
        <span class="eyebrow">The bigger picture</span>
        <h1>
          Where pgvis is going —
          <span class="gradient-text">openly, one milestone at a time</span>
        </h1>
        <p class="subtitle">
          pgvis is an I/O-free Rust engine that turns Postgres and SQLite into MCP, REST, and OpenAPI.
          The roadmap below is concrete and code-driven — built in the open, under the Apache-2.0
          license.
        </p>
        <div class="cta-group">
          <a href="https://github.com/storyvis/pgvis" class="btn btn-primary" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.51-1.47.11-3.07 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.6.23 2.78.11 3.07.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
            </svg>
            Track the work on GitHub
          </a>
          <a href="/introduction" class="btn btn-secondary">Read the docs</a>
        </div>
      </div>
    </section>

    <section class="vision-roadmap-section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Roadmap</span>
          <h2>Milestones to 1.0</h2>
          <p class="section-sub">
            pgvis is in beta — no git tags or release notes have been cut yet, so what's "shipped" below means
            "lives on `main` and is exercised by the test suite." Each row is a concrete piece of work, not a
            marketing line.
          </p>
        </div>
        <ol class="vision-roadmap">
          {milestones.map((m) => (
            <li class={`vision-milestone status-${m.status}`}>
              <div class="vision-milestone-head">
                <span class="vision-milestone-version" set:html={m.phase} />
                <span class={`vision-milestone-status status-${m.status}`}>
                  {statusLabels[m.status]}
                </span>
              </div>
              <h3 set:html={m.title} />
              <p set:html={m.body.replace(/`([^`]+)`/g, "<code>$1</code>")} />
            </li>
          ))}
        </ol>
        <p class="vision-source">
          Source: <a href="https://github.com/storyvis/pgvis" rel="noopener">commits on `main`</a>
        </p>
      </div>
    </section>

    <section class="cta-bottom">
      <div class="container">
        <h2>Want to shape what 1.0 looks like?</h2>
        <p>
          Issues, design feedback, and PRs all land on GitHub. The early roadmap moves fastest
          when the people using pgvis are the ones telling us where it's tight.
        </p>
        <div class="cta-group">
          <a href="https://github.com/storyvis/pgvis/issues" class="btn btn-primary" rel="noopener">
            Open an issue
          </a>
          <a href="https://github.com/storyvis/pgvis" class="btn btn-secondary" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55v-1.93c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.51-1.47.11-3.07 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.6.23 2.78.11 3.07.74.8 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
            </svg>
            Star on GitHub
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
